generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Node.js (PascalCase) Enums
// ─────────────────────────────────────────────────────────────────────────────

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AttendanceStatus {
  NOT_CHECKED_IN
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CANCELLED_BEFORE_START
}

enum UserRole {
  STUDENT
  COACH
  ADMIN
  DEAN
  MANAGER
}

enum FacilityStatus {
  OPEN
  MAINTENANCE
  TOURNAMENT
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntity {
  USER
  FACILITY
  BOOKING
  VIOLATION
  PENALTY
}

enum RestrictionType {
  BAN
  SUSPENSION
  ACCESS_RESTRICTION
}

enum PenaltyType {
  WARNING
  BAN
  COMPENSATION
  SUSPENSION
  DISCIPLINARY_REFERRAL
  ACCESS_RESTRICTION
}

enum ViolationSeverity {
  MINOR
  MAJOR
  CRITICAL
}

enum ViolationStatus {
  OPEN
  RESOLVED
  DISPUTED
}

enum ViolationType {
  LATE_ARRIVAL
  EQUIPMENT_DAMAGE
  BEHAVIORAL
  PHYSICAL_ASSAULT
  FOOD_DRINK
  UNSUITABLE_SHOES
  NO_BOOKING
  SMOKING
  FACILITY_RULE_BREACH
}

enum NotificationChannel {
  EMAIL
  APP
  SMS
  PUSH
  WEBHOOK
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationStatus {
  QUEUED
  PROCESSING
  SENT
  FAILED
  ARCHIVED
}

enum NotificationType {
  SYSTEM
  BOOKING
  ATTENDANCE
  SECURITY
  ACCOUNT
  REWARD
}

// ─────────────────────────────────────────────────────────────────────────────
// Spring Boot (Lowercase) Enums
// ─────────────────────────────────────────────────────────────────────────────

enum bookings_attendance_status {
  CANCELLED_BEFORE_START
  CHECKED_IN
  CHECKED_OUT
  NOT_CHECKED_IN
  NO_SHOW
}

enum notifications_type {
  BOOKING_CANCELLED
  BOOKING_CONFIRMED
  BOOKING_REMINDER
  FEEDBACK_RECEIVED
  POINTS_EARNED
  PROMOTIONAL
  SYSTEM_ALERT
}

enum booking_status {
  PENDING
  APPROVED
  REJECTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum user_role {
  STUDENT
  COACH
  ADMIN
  DEAN
  MANAGER
}

enum users_role {
  ADMIN
  COACH
  STUDENT
}

enum facility_status {
  OPEN
  MAINTENANCE
  TOURNAMENT
  CLOSED
}

enum bookings_status {
  CANCELLED
  COMPLETED
  CONFIRMED
  PENDING
  REJECTED
}

enum feedback_type {
  BUG_REPORT
  FACILITY_REVIEW
  GENERAL_FEEDBACK
  RECOMMENDATION
  SERVICE_FEEDBACK
}

enum booking_attendanceStatus {
  NOT_CHECKED_IN
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CANCELLED_BEFORE_START
}

enum bookings_attendanceStatus {
  CANCELLED_BEFORE_START
  CHECKED_IN
  CHECKED_OUT
  NOT_CHECKED_IN
  NO_SHOW
}

// ─────────────────────────────────────────────────────────────────────────────
// Spring Boot Models (Legacy/Plural Tables)
// ─────────────────────────────────────────────────────────────────────────────

model audit_logs {
  id         BigInt   @id @default(autoincrement())
  action     String   @db.VarChar(255)
  created_at DateTime @db.DateTime(6)
  details    String?  @db.Text
  ip_address String?  @db.VarChar(255)
  user_agent String?  @db.VarChar(255)
  admin_id   BigInt
  ipAddress  String?  @db.VarChar(255)
  userAgent  String?  @db.VarChar(255)
  users      users    @relation(fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FKipd9i0r8h4lyhkehn7nm5qkc0")

  @@index([action], map: "idx_action")
  @@index([admin_id], map: "idx_admin_id")
  @@index([created_at], map: "idx_created_at")
}

model bookings {
  id                     BigInt                      @id @default(autoincrement())
  attendance_status      bookings_attendance_status?
  checked_in_at          DateTime?                   @db.DateTime(6)
  checked_out_at         DateTime?                   @db.DateTime(6)
  conflict_id            String?                     @db.VarChar(255)
  created_at             DateTime                    @db.DateTime(6)
  distance_from_facility Float?
  end_time               DateTime                    @db.DateTime(6)
  participants           Int
  start_time             DateTime                    @db.DateTime(6)
  status                 bookings_status
  student_latitude       Float?
  student_longitude      Float?
  verified_by            String?                     @db.VarChar(255)
  facility_id            BigInt
  user_id                BigInt
  scanned_id_data        String?                     @db.VarChar(255)
  attendanceStatus       bookings_attendanceStatus?
  checkedInAt            DateTime?                   @db.DateTime(6)
  checkedOutAt           DateTime?                   @db.DateTime(6)
  conflictId             String?                     @db.VarChar(255)
  distanceFromFacility   Float?
  scannedIdData          String?                     @db.VarChar(255)
  studentLatitude        Float?
  studentLongitude       Float?
  verifiedBy             String?                     @db.VarChar(255)
  users                  users                       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FKeyog2oic85xg7hsu2je2lx3s6")
  facilities             facilities                  @relation(fields: [facility_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FKovcktajgjh8wo5wrx0e2j2jpd")

  @@index([user_id], map: "FKeyog2oic85xg7hsu2je2lx3s6")
  @@index([facility_id], map: "FKovcktajgjh8wo5wrx0e2j2jpd")
}

model facilities {
  id                                        BigInt             @id @default(autoincrement())
  active                                    Boolean            @db.Bit(1)
  category                                  String             @db.VarChar(255)
  close_time                                String?            @db.VarChar(255)
  default_slot_mins                         Int?
  geofencing_radius                         Float?
  latitude                                  Float?
  longitude                                 Float?
  max_participants                          Int?
  min_participants                          Int?
  name                                      String             @unique(map: "UK6tm0w2xajnx3l566muxq8apmq") @db.VarChar(255)
  open_time                                 String?            @db.VarChar(255)
  sports                                    String?            @db.Text
  status                                    String?            @db.VarChar(255)
  status_reason                             String?            @db.Text
  closeTime                                 String?            @db.VarChar(255)
  defaultSlotMins                           Int?
  geofencingRadius                          Float?
  maxParticipants                           Int?
  minParticipants                           Int?
  openTime                                  String?            @db.VarChar(255)
  statusReason                              String?            @db.Text
  bookings                                  bookings[]
  feedback_feedback_facility_idTofacilities Feedback[]         @relation("feedback_facility_idTofacilities")
  waitlist_entries                          waitlist_entries[]
}

model medical_records {
  id            BigInt   @id @default(autoincrement())
  created_at    DateTime @db.DateTime(6)
  description   String?  @db.Text
  document_name String?  @db.VarChar(255)
  document_url  String?  @db.VarChar(512)
  status        String   @db.VarChar(255)
  submitted_by  String?  @db.VarChar(255)
  user_id       BigInt
  documentName  String?  @db.VarChar(255)
  documentUrl   String?  @db.VarChar(512)
  submittedBy   String?  @db.VarChar(255)
  users         users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FKdd9qwwn228b1yaci52j69dkp4")

  @@index([user_id], map: "FKdd9qwwn228b1yaci52j69dkp4")
}

model notifications {
  id         BigInt             @id @default(autoincrement())
  created_at DateTime           @db.DateTime(6)
  message    String             @db.Text
  is_read    Boolean            @db.Bit(1)
  title      String             @db.VarChar(255)
  type       notifications_type
  user_id    BigInt
  users      users              @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK9y21adhxn0ayjhfocscqox7bh")

  @@index([user_id], map: "FK9y21adhxn0ayjhfocscqox7bh")
}

model system_rules {
  id                                 BigInt   @id @default(autoincrement())
  advance_booking_window_days        Int?
  allow_back_to_back_bookings        Boolean? @db.Bit(1)
  auto_ban_warning_threshold         Int?
  global_email_notifications_enabled Boolean? @db.Bit(1)
  max_booking_duration_mins          Int?
  max_bookings_per_user_per_day      Int?
  min_booking_duration_mins          Int?
  priority_booking_enabled           Boolean? @db.Bit(1)
  priority_early_access_hours        Int?
  priority_score_threshold           Int?
  advanceBookingWindowDays           Int?
  allowBackToBackBookings            Boolean? @db.Bit(1)
  autoBanWarningThreshold            Int?
  globalEmailNotificationsEnabled    Boolean? @db.Bit(1)
  maxBookingDurationMins             Int?
  maxBookingsPerUserPerDay           Int?
  minBookingDurationMins             Int?
  priorityBookingEnabled             Boolean? @db.Bit(1)
  priorityEarlyAccessHours           Int?
  priorityScoreThreshold             Int?
}

model users {
  id                  BigInt             @id @default(autoincrement())
  active_bookings     Int?
  banned              Boolean            @db.Bit(1)
  earned_points       Int?
  email               String             @unique(map: "UK6dotkott2kjsp8vw4d0m25fb7") @db.VarChar(255)
  email_notifications Boolean?           @db.Bit(1)
  full_name           String?            @db.VarChar(255)
  push_notifications  Boolean?           @db.Bit(1)
  role                users_role
  warnings            Int
  credits             Int
  barcode             String?            @unique(map: "UKi095je3dnvjnhvteqhmok2gc6") @db.VarChar(255)
  student_id          String?            @unique(map: "UKqh3otyipv2k9hqte4a1abcyhq") @db.VarChar(255)
  activeBookings      Int?
  earnedPoints        Int?
  emailNotifications  Boolean?           @db.Bit(1)
  fullName            String?            @db.VarChar(255)
  pushNotifications   Boolean?           @db.Bit(1)
  studentId           String?            @unique(map: "UKolxe15b9ax5ojsnv4ig6g6n7") @db.VarChar(255)
  skillLevel          String?            @db.VarChar(50)
  deviceId            String?            @db.VarChar(255)
  device_id           String?            @db.VarChar(255)
  otpCode             String?            @db.VarChar(255)
  otp_code           String?            @db.VarChar(255)
  otpExpiry           DateTime?          @db.DateTime(6)
  otp_expiry          DateTime?          @db.DateTime(6)
  pendingDeviceId     String?            @db.VarChar(255)
  pending_device_id   String?            @db.VarChar(255)
  deviceChangeStatus  String?            @db.VarChar(50)
  device_change_status String?           @db.VarChar(50)
  deviceChangeRequestedAt DateTime?      @db.DateTime(6)
  device_change_requested_at DateTime?   @db.DateTime(6)
  audit_logs          audit_logs[]
  bookings            bookings[]
  feedback            Feedback[]
  medical_records     medical_records[]
  notifications       notifications[]
  waitlist_entries    waitlist_entries[]
}

model waitlist_entries {
  id                 BigInt     @id @default(autoincrement())
  created_at         DateTime?  @db.DateTime(6)
  desired_start_time DateTime?  @db.DateTime(6)
  participants       Int
  facility_id        BigInt
  user_id            BigInt
  createdAt          DateTime?  @db.DateTime(6)
  desiredStartTime   DateTime?  @db.DateTime(6)
  facilities         facilities @relation(fields: [facility_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK5668m6tlre17gx47jbh3tk351")
  users              users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FKdpgl4h9wd7kabg6dk86wdvjqy")

  @@index([facility_id], map: "FK5668m6tlre17gx47jbh3tk351")
  @@index([user_id], map: "FKdpgl4h9wd7kabg6dk86wdvjqy")
}

// ─────────────────────────────────────────────────────────────────────────────
// Node.js Models (PascalCase, mapped via @@map to lowercase tables)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                String         @id @default(cuid())
  studentId         String         @unique(map: "User_studentId_key")
  phone             String?        @unique(map: "User_phone_key")
  fullName          String?
  email             String?        @unique(map: "User_email_key")
  college           String?
  barcode           String?        @unique(map: "User_barcode_key")
  passwordHash      String
  role              UserRole       @default(STUDENT)
  managedFacilityId String?
  points            Int            @default(0)
  warnings          Int            @default(0)
  isBanned          Boolean        @default(false)
  banReason         String?
  bannedAt          DateTime?
  banExpiresAt      DateTime?
  createdAt         DateTime       @default(now())
  skillLevel        String         @default("Intermediate")

  bookings            Booking[]
  managedFacility     Facility?            @relation("CoachManagedFacility", fields: [managedFacilityId], references: [id], map: "User_managedFacilityId_fkey")
  bookingParticipants BookingParticipant[]
  matchmakingQueues   MatchmakingQueue[]
  adminLogs           AdminLog[]           @relation("AdminActionLogs")
  medicalRecords      MedicalRecord[]
  dailyUsages         DailyUsage[]
  feedbacks           Feedback[]
  notifications       Notification[]
  rewards             UserReward[]
  violations          Violation[]
  restrictions        UserRestriction[]

  @@index([managedFacilityId], map: "User_managedFacilityId_fkey")
  @@map("user")
}

model Sport {
  id                String             @id @default(cuid())
  name              String             @unique(map: "Sport_name_key")
  icon              String?
  description       String?
  minParticipants   Int                @default(1)
  maxParticipants   Int                @default(20)
  durationOptions   String             @default("30,60,90")
  requiresCoach     Boolean            @default(false)
  idealParticipants Int                @default(10)
  
  facilities        Facility[]
  bookings          Booking[]
  matchmakingQueues MatchmakingQueue[]
  weeklyStats       WeeklySportStats[]

  @@map("sport")
}

model Facility {
  id                String          @id @default(cuid())
  name              String          @unique(map: "Facility_name_key")
  sportId           String?
  sports            String?         @db.Text
  category          String
  defaultSlotMins   Int             @default(60)
  openTime          String
  closeTime         String
  minParticipants   Int             @default(1)
  maxParticipants   Int             @default(20)
  status            FacilityStatus  @default(OPEN)
  statusReason      String?
  isActive          Boolean         @default(true)
  feedbackEnabled   Boolean         @default(true)
  latitude          Float?
  longitude         Float?
  geofencingRadius  Float?
  createdAt         DateTime        @default(now())

  bookings          Booking[]
  sport             Sport?          @relation(fields: [sportId], references: [id], map: "Facility_sportId_fkey")
  coaches           User[]          @relation("CoachManagedFacility")
  dailyUsages       DailyUsage[]
  feedbacks         Feedback[]
  matchmakingQueues MatchmakingQueue[]

  @@index([sportId], map: "Facility_sportId_fkey")
  @@map("facility")
}

model Conflict {
  id          String    @id @default(cuid())
  description String
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())
  bookings    Booking[]

  @@map("conflict")
}

model Booking {
  id                   String           @id @default(cuid())
  userId               String
  facilityId           String
  startTime            DateTime
  endTime              DateTime
  participants     Int
  status           BookingStatus    @default(PENDING)
  requiresApproval Boolean          @default(false)
  approverRole     String?
  conflictId       String?
  rejectionReason  String?
  reminderSent     Boolean          @default(false)
  termsAccepted    Boolean          @default(false)
  buddyIds         String           @default("[]")
  attendanceStatus AttendanceStatus @default(NOT_CHECKED_IN)
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  studentLatitude  Float?
  studentLongitude Float?
  distanceFromFacility Float?
  verifiedBy       String?
  createdAt        DateTime         @default(now())
  sportId          String?

  conflict         Conflict?        @relation(fields: [conflictId], references: [id], onDelete: SetNull, map: "Booking_conflictId_fkey")
  facility         Facility         @relation(fields: [facilityId], references: [id], map: "Booking_facilityId_fkey")
  user             User             @relation(fields: [userId], references: [id], map: "Booking_userId_fkey")
  sport            Sport?           @relation(fields: [sportId], references: [id], onDelete: SetNull)
  bookingParticipants BookingParticipant[]

  @@index([conflictId], map: "Booking_conflictId_fkey")
  @@index([facilityId, startTime, endTime], map: "Booking_facilityId_startTime_endTime_idx")
  @@index([userId], map: "Booking_userId_fkey")
  @@map("booking")
}

model Feedback {
  id                                          BigInt        @id @default(autoincrement())
  rating                                      Int
  bookingId                                   String?
  booking_id                                  BigInt?
  comment                                     String?
  createdAt                                   DateTime?     @default(now())
  facilityId                                  String?       // Kept as String? for compatibility with Node.js Facility IDs
  isAnonymous                                 Boolean       @default(false)
  userId                                      String?
  content                                     String?       @db.Text
  created_at                                  DateTime?     @db.DateTime(6)
  type                                        feedback_type?
  user_id                                     BigInt?
  facility_id                                 BigInt?

  user                                        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  facility                                    Facility?     @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  facilities_feedback_facility_idTofacilities facilities?   @relation("feedback_facility_idTofacilities", fields: [facility_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK9c5da9vnu0n9n8ddnvq234ruv")
  users                                       users?        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FKpwwmhguqianghvi1wohmtsm8l")

  @@index([facility_id], map: "FK9c5da9vnu0n9n8ddnvq234ruv")
  @@index([user_id], map: "FKpwwmhguqianghvi1wohmtsm8l")
  @@index([facilityId, createdAt], map: "Feedback_facilityId_createdAt_idx")
  @@map("feedback")
}

model Notification {
  id            String               @id @default(cuid())
  userId        String
  title         String
  message       String
  channel       NotificationChannel  @default(EMAIL)
  read          Boolean              @default(false)
  createdAt     DateTime             @default(now())
  status        NotificationStatus   @default(QUEUED)
  failureReason String?
  failedAt      DateTime?
  sentAt        DateTime?
  readAt        DateTime?
  nextRetryAt   DateTime?
  expiresAt     DateTime?
  attemptCount  Int                  @default(0)
  maxAttempts   Int                  @default(3)
  priority      NotificationPriority @default(NORMAL)
  type          NotificationType     @default(SYSTEM)
  actionUrl     String?
  payload       Json?
  dedupeKey     String?

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "Notification_userId_createdAt_idx")
  @@map("notification")
}

model SystemRule {
  id                    String   @id @default(cuid())
  maxBookingsPerDay     Int      @default(1)
  autoBanThreshold      Int      @default(3)
  advanceBookingWindow  Int      @default(7)
  minimumNoticeTime     Int      @default(24)
  updatedAt             DateTime @updatedAt

  @@map("systemrule")
}

model Reward {
  id          String   @id @default(cuid())
  name        String
  description String
  pointsCost  Int
  rewardType  String

  users       UserReward[]
  @@map("reward")
}

model UserReward {
  id         String   @id @default(cuid())
  userId     String
  rewardId   String
  redeemedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward     Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@map("userreward")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  admin     User     @relation("AdminActionLogs", fields: [adminId], references: [id], onDelete: Cascade)
  @@map("adminlog")
}

model MedicalRecord {
  id          String   @id @default(cuid())
  userId      String
  documentUrl String
  description String?
  isEncrypted Boolean  @default(true)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medicalrecord")
}

model DailyUsage {
  id            String   @id @default(cuid())
  userId        String
  facilityId    String
  studentId     String   @default("")
  studentName   String   @default("")
  facilityName  String   @default("")
  date          String
  usedMins      Int      @default(0)
  remainingMins Int      @default(60)
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility      Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([userId, facilityId, date], map: "DailyUsage_userId_facilityId_date_key")
  @@map("dailyusage")
}

// ─────────────────────────────────────────────────────────────────────────────
// Matchmaking, Team, and Fairness Models
// ─────────────────────────────────────────────────────────────────────────────

model BookingParticipant {
  id        String  @id @default(uuid())
  bookingId String
  userId    String
  team      String  @default("A") // "A" or "B" for auto team balancing

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookingId, userId])
}

model MatchmakingQueue {
  id          String   @id @default(uuid())
  userId      String
  sportId     String
  facilityId  String
  date        String   // e.g. "2026-06-05"
  timeSlot    String   // e.g. "10:00"
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport       Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  facility    Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([userId, sportId, date, timeSlot])
}

model FairnessConfig {
  id                           BigInt @id @default(autoincrement())
  primeTimeStartHour           Int    @default(17)
  primeTimeEndHour             Int    @default(21)
  basketballQuotaPercent       Float  @default(60.0)
  volleyballQuotaPercent       Float  @default(40.0)
  cooldownPeriodHours          Int    @default(24)
  maxWeeklyReservationsPerUser Int    @default(3)
  consecutiveSlotLimit         Int    @default(2)
  teamOverlapThresholdPercent  Float  @default(50.0)
  playerWeightCoeff            Float  @default(0.4)
  unusedHoursWeightCoeff       Float  @default(0.3)
  primeTimeDisadvantageCoeff   Float  @default(0.3)

  @@map("fairness_config")
}

model WeeklySportStats {
  id                    String @id @default(uuid())
  year                  Int
  weekNumber            Int
  sportId               String
  bookedHours           Float  @default(0.0)
  activePlayersCount    Int    @default(0)
  primeTimeHoursUsed    Float  @default(0.0)
  rejectedBookingsCount Int    @default(0)

  sport                 Sport  @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([year, weekNumber, sportId], name: "year_weekNumber_sportId")
  @@map("weekly_sport_stats")
}

// ─────────────────────────────────────────────────────────────────────────────
// Violation and Penalty Engine Models (Added)
// ─────────────────────────────────────────────────────────────────────────────

model Violation {
  id                 String            @id @default(uuid())
  userId             String
  type               ViolationType
  severity           ViolationSeverity @default(MINOR)
  status             ViolationStatus   @default(OPEN)
  description        String?
  bookingId          String?
  facilityId         String?
  evidenceUrl        String?
  reportedById       String?
  metadata           Json?
  dedupeKey          String?           @unique
  createdAt          DateTime          @default(now())
  resolvedAt         DateTime?

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  penalties          Penalty[]
  @@map("violation")
}

model Penalty {
  id          String      @id @default(uuid())
  userId      String
  violationId String?
  type        PenaltyType
  amount      Float?
  currency    String?
  reason      String?
  startAt     DateTime?
  endAt       DateTime?
  metadata    Json?
  createdAt   DateTime    @default(now())

  violation   Violation?  @relation(fields: [violationId], references: [id], onDelete: SetNull)
  @@map("penalty")
}

model UserRestriction {
  id          String          @id @default(uuid())
  userId      String
  type        RestrictionType
  reason      String?
  startAt     DateTime        @default(now())
  endAt       DateTime?
  createdById String?
  createdAt   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_restriction")
}

model AuditLog {
  id          String      @id @default(uuid())
  userId      String?
  action      AuditAction
  entity      AuditEntity
  entityId    String?
  description String?
  oldValue    Json?
  newValue    Json?
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@map("audit_log")
}

model NotificationPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  appEnabled        Boolean  @default(true)
  emailEnabled      Boolean  @default(true)
  smsEnabled        Boolean  @default(false)
  pushEnabled       Boolean  @default(false)
  bookingEnabled    Boolean  @default(true)
  attendanceEnabled Boolean  @default(true)
  securityEnabled   Boolean  @default(true)
  accountEnabled    Boolean  @default(true)
  rewardEnabled     Boolean  @default(true)
  quietHoursStart   Int?
  quietHoursEnd     Int?
  timezone          String?  @default("UTC")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("notification_preference")
}

model NotificationDeliveryLog {
  id             String   @id @default(uuid())
  notificationId String
  channel        String
  attempt        Int
  status         String
  provider       String?
  providerId     String?
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@map("notification_delivery_log")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  type        String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_setting")
}
