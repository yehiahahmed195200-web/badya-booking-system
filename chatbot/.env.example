# Optional OpenAI API key for real LLM calls
OPENAI_API_KEY=
# Optional generic key name (used if OPENAI_API_KEY is empty)
LLM_API_KEY=
# OpenRouter key (auto-switches base URL if set)
OPENROUTER_API_KEY=
# Optional custom OpenAI-compatible endpoint (OpenRouter, local gateway, etc.)
LLM_BASE_URL=
# Optional model name
LLM_MODEL=gpt-4o-mini

# Port for chatbot server
CHATBOT_PORT=3333
